rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isFacilitator(roomCode) {
      return isSignedIn() && get(/databases/$(database)/documents/rooms/$(roomCode)/participants/$(request.auth.uid)).data.role == 'admin';
    }

    // Validation Blueprints
    function isValidCard(data, isCreate) {
      return data.keys().hasAll(['id', 'title', 'author', 'content', 'color', 'likes', 'timestamp', 'authorId', 'comments']) 
             && data.keys().size() >= 9
             && data.id is string && data.id.size() <= 100
             && data.title is string && data.title.size() <= 150
             && data.author is string && data.author.size() <= 50
             && data.content is string && data.content.size() <= 2000
             && data.color in ['yellow', 'pink', 'purple', 'cyan', 'green']
             && data.likes is number
             && data.timestamp is number
             && (isCreate ? data.authorId == request.auth.uid : true) // Relaxed for updates by admin
             && data.comments is list;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'user', 'userId', 'text', 'type', 'timestamp'])
             && data.keys().size() >= 6
             && data.id is string && data.id.size() <= 100
             && data.user is string && data.user.size() <= 50
             && data.userId == request.auth.uid
             && data.text is string && data.text.size() <= 1000
             && data.type in ['chat', 'resource', 'file']
             && data.timestamp is number;
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['id', 'name', 'lastSeen', 'role'])
             && data.keys().size() == 4
             && data.id == request.auth.uid
             && data.name is string && data.name.size() <= 50
             && data.lastSeen is number
             && data.role in ['admin', 'user'];
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['title'])
             && data.title is string && data.title.size() <= 100;
    }

    // Room Context
    match /rooms/{roomCode} {
      allow get: if isSignedIn();
      // Allow creation/update if signed in. Note: In a real app, you might want more checks on room creation.
      allow create: if isSignedIn() && isValidRoom(incoming());
      allow update: if isSignedIn() && (
        isFacilitator(roomCode) || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['title']) && isValidRoom(incoming()))
      );
      
      match /cards/{cardId} {
        // Secure List Query: In this app, everyone in the room sees all cards.
        // We lack a robust "room membership" check without costly reads in 'list',
        // but at minimum we check isSignedIn.
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        
        allow create: if isSignedIn() && isValidCard(incoming(), true) && isValidId(cardId);
        
        allow update: if isSignedIn() && isValidCard(incoming(), false) && (
          // Action: Facilitator Edit
          isFacilitator(roomCode) ||
          // Action: Author Edit (Immutability check for authorId)
          (existing().authorId == request.auth.uid && incoming().authorId == existing().authorId) ||
          // Action: Like (Atomic increment pattern check could be added here)
          (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && incoming().likes == existing().likes + 1) ||
          // Action: Comment
          (incoming().diff(existing()).affectedKeys().hasOnly(['comments']) && incoming().comments.size() > existing().comments.size())
        );

        allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isFacilitator(roomCode));
      }

      match /messages/{messageId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create: if isSignedIn() && isValidMessage(incoming()) && isValidId(messageId);
      }

      match /participants/{participantId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create, update: if isSignedIn() && isValidParticipant(incoming()) && participantId == request.auth.uid;
        allow delete: if isSignedIn() && participantId == request.auth.uid;
      }
    }
  }
}
