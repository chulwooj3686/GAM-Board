# ──────────────────────────────────────────────
# Firebase 설정 (firebase-applet-config.json 대체)
# ──────────────────────────────────────────────
# VITE_ 접두사는 Vite 클라이언트 번들에 포함됨.
# 아래 값들은 Firebase 콘솔 > 프로젝트 설정에서 확인.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# ──────────────────────────────────────────────
# Google Sheets 내보내기 (서버 전용, VITE_ 접두사 없음)
# ──────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# ──────────────────────────────────────────────
# 퍼실리테이터 인증 (서버 전용)
# 절대 VITE_ 접두사를 붙이지 말 것 — 클라이언트 번들에 노출됨
# ──────────────────────────────────────────────
FACILITATOR_PASSWORD=

# Gemini AI (서버 전용)
GEMINI_API_KEY=
